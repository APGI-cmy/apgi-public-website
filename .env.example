# APW public configuration only. Do not place secrets in this file.

# Public canonical site URL used by Astro for metadata and canonical links.
APW_PUBLIC_SITE_URL=https://apginc.ca

# Optional public APGI Hub / ISMS base URL. If unset, Hub module links render as governed pending states.
ISMS_PUBLIC_BASE_URL=

# Optional public Maturion chat gateway endpoint.
# Example: https://maturion-ai-gateway.onrender.com/api/v1/public-chat
APW_PUBLIC_MATURION_CHAT_ENDPOINT=

# Set to false to hide the public Maturion chat widget without removing code.
APW_PUBLIC_MATURION_CHAT_ENABLED=true
