# APW Public Website environment example
# This file is required by the architecture completeness canon.
# Use placeholder/public values only. Do not place secrets in this file.

# Purpose: Public APGI Hub / ISMS base URL used to compose Platform/APGI Hub module links.
# Format: Absolute URL without trailing slash, for example https://example-hub.vercel.app
# Required: NO for pre-launch preview; YES before Hub external-link evidence can be closed green.
# Source: Owner-provided / Vercel project environment variable.
ISMS_PUBLIC_BASE_URL=https://example-hub.vercel.app

# Purpose: Public canonical base URL for the APW website when final production domain is known.
# Format: Absolute URL without trailing slash, for example https://apginc.ca
# Required: NO for preview; YES before final production SEO/social evidence can be closed green.
# Source: Owner-provided / Vercel project environment variable.
APW_PUBLIC_SITE_URL=https://example-apw.vercel.app
