---
import BaseLayout from '../layouts/BaseLayout.astro';
import { routes, services, hubModules, trainingOffers, site, hubHref, lossTypes, maturityJourney, freeAssessment, freeAssessmentHref, situationAwareness, learningPattern } from '../data/site';
const route = routes.find((item) => item.key === 'home');
const assessmentHref = freeAssessmentHref();
---
<BaseLayout title={route?.title} description={route?.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Loss prevention through maturity</p>
        <h1>Reduce the opportunities that become loss.</h1>
        <p class="lead">APGI helps organizations prevent malicious and non-malicious loss by assessing maturity, identifying gaps, building a roadmap and supporting implementation through consulting, tools, training, monitoring and assurance.</p>
        <div class="cta-row">
          {assessmentHref ? <a class="button" href={assessmentHref}>{freeAssessment.cta}</a> : <a class="button" href="/contact">Request free assessment access</a>}
          <a class="button secondary" href="/platform">Explore the maturity journey</a>
        </div>
      </div>
      <aside class="hero-card" aria-label="APGI maturity journey">
        <h2>From exposed to resilient.</h2>
        <p>APGI connects criteria-based assessment, maturity scoring, gap identification, roadmap planning, implementation tracking, remote assurance and training into one improvement journey.</p>
        <p>{assessmentHref ? 'The free assessment starts in the APGI Hub / ISMS environment.' : 'The deeper assessment destination is governed as a pending APGI Hub / ISMS handoff until the public base URL is configured.'}</p>
      </aside>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The loss-prevention model</p>
        <h2>Loss is created when opportunity meets weak or immature controls.</h2>
        <p>APGI treats process failures, weak procedures, poor data, human error and deliberate exploitation as connected loss-prevention problems. The work is to reduce opportunity, detect weak signals and build resilient operations.</p>
      </div>
      <div class="grid two">
        {lossTypes.map((loss) => <article class="card"><h3>{loss.name}</h3><p><strong>{loss.summary}</strong></p><p>{loss.detail}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Maturity journey</p>
        <h2>Assess, understand, improve and assure.</h2>
        <p>The website and APGI Hub must guide visitors through a maturity journey, not a disconnected list of services or app cards.</p>
      </div>
      <div class="grid">
        {maturityJourney.map((item, index) => <article class="card"><span class="status">Step {index + 1}</span><h3>{item.step}</h3><p>{item.detail}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container proof-panel">
      <p class="eyebrow">{freeAssessment.eyebrow}</p>
      <h2>{freeAssessment.heading}</h2>
      <p>{freeAssessment.detail}</p>
      <div class="cta-row">
        {assessmentHref ? <a class="button" href={assessmentHref}>{freeAssessment.cta}</a> : <a class="button" href="/contact">{freeAssessment.fallback}</a>}
        <a class="button secondary" href="/platform">See how the roadmap works</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Services preview</p>
        <h2>Consulting, assurance and training support the roadmap.</h2>
      </div>
      <div class="grid two">
        {services.map((service) => <article class="card"><h3>{service.name}</h3><p><strong>Need:</strong> {service.need}</p><p><strong>Outcome:</strong> {service.outcome}</p><a href={service.cta}>Continue</a></article>)}
      </div>
      <div class="cta-row"><a class="button" href="/services">View all services</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">APGI Hub preview</p>
        <h2>Each module has a role in the same maturity journey.</h2>
      </div>
      <div class="grid">
        {hubModules.slice(0, 6).map((module) => <article class="card"><span class="status">{module.role}</span><h3>{module.name}</h3><p>{module.journey}</p><p class="muted">{hubHref(module.slug) ? 'Public Hub link available.' : 'Pending Hub base URL.'}</p></article>)}
      </div>
      <div class="cta-row"><a class="button" href="/platform">Explore APGI Hub</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Real-time situational awareness</p>
        <h2>Mature operations know what is happening before loss becomes normal.</h2>
        <p>APGI's roadmap increasingly connects work, risk, controls, evidence, exceptions and escalation so organizations can intervene earlier.</p>
      </div>
      <div class="grid two">
        {situationAwareness.map((item) => <article class="card"><p>{item}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Hover / click / ask / train</p>
        <h2>Complex concepts need layered learning.</h2>
      </div>
      <div class="grid">
        {learningPattern.map((item) => <article class="card"><h3>{item.label}</h3><p>{item.detail}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Training preview</p>
        <h2>Training builds the capability needed to move up the maturity scale.</h2>
      </div>
      <div class="grid">
        {trainingOffers.map((offer) => <article class="card"><span class="status">{offer.status}</span><h3>{offer.name}</h3><p>{offer.detail}</p></article>)}
      </div>
      <div class="cta-row"><a class="button" href={site.thinkificUrl}>Open Thinkific storefront</a><a class="button secondary" href="/training">View training page</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container proof-panel">
      <p class="eyebrow">Contact path</p>
      <h2>Ready to discuss maturity, risk, training or assurance needs?</h2>
      <p>Use public handoffs only: email, phone and contact route. No backend form capture is introduced.</p>
      <div class="cta-row"><a class="button" href="/contact">Contact APGI</a><a class="button secondary" href={`mailto:${site.email}`}>{site.email}</a></div>
    </div>
  </section>
</BaseLayout>
